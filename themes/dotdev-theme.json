{
  "name": "dotdev-theme",
  "type": "dark",
  "colors": {
    "window.activeBorder": "#000000",
    "window.inactiveBorder": "#000000",
    "panel.border": "#000000",
    "panelTitle.activeBorder": "#000000",
    "panelTitle.inactiveForeground": "#ffffff",
    "statusBar.debuggingBorder": "#000000",
    "statusBar.noFolderBorder": "#000000",
    "statusBar.prominentBackground": "#000000",
    "statusBar.prominentForeground": "#ffffff",
    "statusBar.prominentHoverBackground": "#000000",
    "statusBarItem.prominentBackground": "#000000",
    "statusBarItem.prominentForeground": "#ffffff",
    "statusBarItem.prominentHoverBackground": "#000000",
    "editor.background": "#000000",
    "editor.foreground": "#E6E6E6",
    "editorLineNumber.activeForeground": "#00FF00",
    "statusBarItem.errorForeground": "#FF0000",
    "statusBar.background": "#000000",
    "statusBar.border": "#000000",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#00FF00",
    "activityBar.activeBorder": "#00FF0000",
    "activityBar.border": "#00000000",
    "activityBarBadge.background": "#CC00FF",
    "tab.hoverBackground": "#555555",
    "tab.activeBackground": "#333333",
    "tab.activeBorder": "#00FF00",
    "tab.activeForeground": "#00FF00",
    "tab.unfocusedActiveForeground": "#00FF00",
    "tab.hoverForeground": "#00FF00",
    "tab.inactiveBackground": "#000000",
    "editorGroupHeader.tabsBackground": "#000000",
    "sideBarTitle.foreground": "#FFFFFF",
    "statusBar.foreground": "#FFFFFF",
    "sideBar.foreground": "#FFFFFF",
    "sideBar.background": "#000000",
    "sideBarSectionHeader.background": "#00FF0008",
    "sideBarSectionHeader.foreground": "#ffffff",
    "sideBarSectionHeader.border": "#00FF0010",
    "tree.indentGuidesStroke": "#333333",
    "tree.tableColumnsBorder": "#00FF0020",
    "tree.tableOddRowsBackground": "#00FF0008",
    "editorGroupHeader.tabsBorder": "#000000",
    "focusBorder": "#00FF00",
    "selection.background": "#00FF0030",
    "widget.shadow": "#00000080",
    "tree.inactiveIndentGuidesStroke": "#333333",
    "diffEditor.removedTextBackground": "#F4000045",
    "diffEditor.removedLineBackground": "#F4000045",
    "diffEditor.insertedTextBackground": "#39FF1410",
    "diffEditor.insertedLineBackground": "#39FF1410",
    "diffEditor.diagonalFill": "#00BFFF",
    "diffEditorOverview.insertedForeground": "#39FF14",
    "diffEditorOverview.removedForeground": "#F40000",
    "editorIndentGuide.activeBackground1": "#00ff00",
    "editorIndentGuide.activeBackground2": "#00ff00",
    "editorIndentGuide.activeBackground3": "#00ff00",
    "editorIndentGuide.activeBackground4": "#00ff00",
    "editorIndentGuide.activeBackground5": "#00ff00",
    "editorIndentGuide.activeBackground6": "#00ff00",
    "editorIndentGuide.background1": "#010",
    "editorIndentGuide.background2": "#333",
    "editorIndentGuide.background3": "#666",
    "editorIndentGuide.background4": "#999",
    "editorIndentGuide.background5": "#ccc",
    "editorIndentGuide.background6": "#fff",
    "editor.selectionBackground": "#00FF0025",
    "editor.selectionHighlightBackground": "#00FF0020",
    "editor.wordHighlightStrongBackground": "#00FF0015",
    "editor.lineHighlightBackground": "#00FF0008",
    "editor.lineHighlightBorder": "#00FF0010",
    "list.activeSelectionBackground": "#00FF0030",
    "list.activeSelectionForeground": "#00FF00",
    "list.focusBackground": "#00FF0025",
    "list.focusForeground": "#00FF00",
    "list.inactiveSelectionBackground": "#00FF0015",
    "list.inactiveSelectionForeground": "#ffffff",
    "list.inactiveFocusBackground": "#00FF0010",
    "list.invalidItemForeground": "#ff5370",
    "list.hoverBackground": "#00FF0020",
    "list.hoverForeground": "#ffffff",
    "list.highlightForeground": "#00FF00",
    "list.filterMatchBackground": "#00FF0030",
    "list.filterMatchBorder": "#00FF00",
    "listFilterWidget.background": "#000000",
    "listFilterWidget.outline": "#00FF00",
    "listFilterWidget.noMatchesOutline": "#FF0000",
    "button.background": "#CC00FF",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#EE00FF",
    "badge.background": "#CC00FF",
    "badge.foreground": "#FFFFFF",
    "activityBarBadge.foreground": "#FFFFFF",
    "textLink.foreground": "#EE00FF",
    "textLink.activeForeground": "#EE00FF",
    "breadcrumb.foreground": "#ffffff",
    "breadcrumb.background": "#000000",
    "breadcrumb.focusForeground": "#00ff00",
    "breadcrumb.activeSelectionForeground": "#00ff00",
    "breadcrumbPicker.background": "#000000"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FFFF00"
      }
    },
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#99DDFF"
      }
    },
    {
      "name": "Variable Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#B3B3FF"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#00FFCC"
      }
    },
    {
      "name": "Template Literal Placeholders",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#00FFCC"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Support",
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.id.html",
        "entity.other.attribute-name.class.html"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name",
        "support.type.vendored.property-name"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FFFF00"
      }
    },
    {
      "name": "CSS Classes and IDs",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.class.scss",
        "entity.other.attribute-name.id.scss"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "JSON Keys - Deep Level 3+",
      "scope": [
        "source.json meta.structure.dictionary.value.json meta.structure.dictionary.value.json meta.structure.dictionary.value.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#F0DDFF"
      }
    },
    {
      "name": "JSON Keys - Deep Level 2",
      "scope": [
        "source.json meta.structure.dictionary.value.json meta.structure.dictionary.value.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#E0BBFF"
      }
    },
    {
      "name": "JSON Keys - Nested Level 1",
      "scope": [
        "source.json meta.structure.dictionary.value.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#D099FF"
      }
    },
    {
      "name": "JSON Keys - Root Level",
      "scope": [
        "source.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "JSON Strings",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "heading.4.markdown",
        "heading.5.markdown",
        "heading.6.markdown",
        "markup.heading.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#99DDFF"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#E6E6E6"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link",
        "string.other.link.markdown"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "Markdown Quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Embedded Section",
      "scope": [
        "punctuation.section.embedded",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Variable Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "meta.decorator punctuation.decorator"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#EE00FF"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#00CC00"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF0099"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "PHP Variables",
      "scope": [
        "variable.other.php",
        "punctuation.definition.variable.php"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Python Decorators",
      "scope": [
        "entity.name.function.decorator.python",
        "punctuation.definition.decorator.python"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#EE00FF"
      }
    },
    {
      "name": "Python Docstrings",
      "scope": [
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "JavaScript Template Literals",
      "scope": [
        "string.template"
      ],
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "Template Expression Brackets Override",
      "scope": [
        "meta.embedded.line.js punctuation.section.embedded",
        "meta.embedded.line.js punctuation.section.embedded.begin",
        "meta.embedded.line.js punctuation.section.embedded.end",
        "string.template meta.embedded.line punctuation.section.embedded",
        "string.template punctuation.section.embedded",
        "string.template.js punctuation.definition.template-expression",
        "string.template.js punctuation.definition.template-expression.begin",
        "string.template.js punctuation.definition.template-expression.end",
        "meta.template.expression punctuation.definition.template-expression",
        "punctuation.definition.template-expression.begin.ts",
        "punctuation.definition.template-expression.end.ts"
      ],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "Template Expression Punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.definition.template-expression.begin.js",
        "punctuation.definition.template-expression.end.js",
        "meta.template.expression.js"
      ],
      "settings": {
        "foreground": "#FF00FF"
      }
    },
    {
      "name": "TypeScript Types",
      "scope": [
        "entity.name.type.ts",
        "entity.name.type.tsx",
        "support.type.primitive.ts",
        "support.type.primitive.tsx"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "JSX/TSX Tags",
      "scope": [
        "entity.name.tag.tsx",
        "entity.name.tag.jsx"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "JSX/TSX Attributes",
      "scope": [
        "entity.other.attribute-name.tsx",
        "entity.other.attribute-name.jsx"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Vue Directives",
      "scope": [
        "punctuation.attribute-shorthand.bind.html.vue",
        "punctuation.attribute-shorthand.event.html.vue"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "YAML Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "TOML Keys",
      "scope": [
        "support.type.property-name.toml"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "Shell Variables",
      "scope": [
        "variable.other.shell"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "SQL Keywords",
      "scope": [
        "keyword.other.sql",
        "keyword.other.DDL.sql",
        "keyword.other.DML.sql"
      ],
      "settings": {
        "foreground": "#BB66FF"
      }
    },
    {
      "name": "SQL Functions",
      "scope": [
        "support.function.aggregate.sql"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    }
  ]
}